# API keys — copy this file to .env and fill in. NEVER commit .env.
GEMINI_API_KEY=
OPENAI_API_KEY=

# Pexels API key — required for Pexels scans through the official API.
# Create one for free at https://www.pexels.com/api/key/ (200 requests/hour, 20,000/month).
# IMPORTANT: An API key alone does not authorize dataset or machine-learning use.
# Configure/use this integration only if Pexels has explicitly authorized this use case.
# Official terms: https://help.pexels.com/hc/en-us/articles/900005880463-What-are-the-Terms-and-Conditions
PEXELS_API_KEY=

# vast.ai API key — enables cloud GPU training (rent a GPU per run, auto-terminated).
# Get one at https://cloud.vast.ai -> Keys. Typical training run costs ~$1-2.
VAST_API_KEY=
